    {
      "name": "Teste 2 - POST /ieee754",
      "item": [
        {
          "name": "CT01 - Decimal positivo válido (0.5)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"valor\": 0.5\n}"
            },
            "url": { "raw": "http://localhost:3000/ieee754", "host": ["localhost"], "port": "3000", "path": ["ieee754"] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test(\"Status code deve ser 200\", function () {",
                "    pm.response.to.have.status(200);",
                "});",
                "pm.test(\"Sinal deve ser 0 (positivo)\", function () {",
                "    var json = pm.response.json();",
                "    pm.expect(json.ieee754.sinal).to.eql(\"0\");",
                "});",
                "pm.test(\"Resposta contém os campos IEEE 754\", function () {",
                "    var json = pm.response.json();",
                "    pm.expect(json.ieee754).to.have.property(\"sinal\");",
                "    pm.expect(json.ieee754).to.have.property(\"expoente\");",
                "    pm.expect(json.ieee754).to.have.property(\"mantissa\");",
                "    pm.expect(json.ieee754).to.have.property(\"binario32\");",
                "});"
              ]
            }
          }]
        },
        {
          "name": "CT02 - Decimal negativo válido (-3.14)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"valor\": -3.14\n}"
            },
            "url": { "raw": "http://localhost:3000/ieee754", "host": ["localhost"], "port": "3000", "path": ["ieee754"] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test(\"Status code deve ser 200\", function () {",
                "    pm.response.to.have.status(200);",
                "});",
                "pm.test(\"Sinal deve ser 1 (negativo)\", function () {",
                "    var json = pm.response.json();",
                "    pm.expect(json.ieee754.sinal).to.eql(\"1\");",
                "});"
              ]
            }
          }]
        },
        {
