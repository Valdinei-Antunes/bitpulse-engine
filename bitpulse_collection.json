{
  "info": {
    "name": "BitPulse Engine - Testes de API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Teste 1 - POST /gate",
      "item": [
        {
          "name": "CT01 - Porta AND com entradas válidas (1,1)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"gate\": \"AND\",\n  \"a\": 1,\n  \"b\": 1\n}"
            },
            "url": { "raw": "http://localhost:3000/gate", "host": ["localhost"], "port": "3000", "path": ["gate"] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test(\"Status code deve ser 200\", function () {",
                "    pm.response.to.have.status(200);",
                "});",
                "pm.test(\"Saída deve ser 1 (AND 1,1)\", function () {",
                "    var json = pm.response.json();",
                "    pm.expect(json.saida).to.eql(1);",
                "});",
                "pm.test(\"Status deve ser sucesso\", function () {",
                "    var json = pm.response.json();",
                "    pm.expect(json.status).to.eql(\"sucesso\");",
                "});"
              ]
            }
          }]
        },
        {
          "name": "CT02 - Porta AND com entradas válidas (1,0)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
